<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="820" d:DesignHeight="600"
        x:Class="DirOpusReImagined.FileViewer"
        Width="820" Height="600" WindowStartupLocation="CenterOwner"
        Title="View">

    <DockPanel LastChildFill="True">

        <!-- Top bar: file name, mode toggle, wrap toggle -->
        <Border DockPanel.Dock="Top" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderSubtleBrush}" Padding="10,6">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBlock Name="InfoText" Grid.Column="0" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" FontWeight="Bold" />
                <CheckBox Name="WrapCheck" Grid.Column="1" Content="Wrap" VerticalAlignment="Center"
                          Margin="8,0" IsChecked="False" IsCheckedChanged="WrapCheck_Changed" />
                <Button Name="ModeButton" Grid.Column="2" Content="Hex" MinWidth="70"
                        FontWeight="Bold" Click="ModeButton_Click" />
            </Grid>
        </Border>

        <!-- Dismiss bar -->
        <Border DockPanel.Dock="Bottom" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource BorderSubtleBrush}" Padding="10,6">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Name="StatusText" Grid.Column="0" VerticalAlignment="Center"
                           Foreground="{DynamicResource MutedTextBrush}" />
                <Button Name="DismissButton" Grid.Column="1" Content="Dismiss" MinWidth="90"
                        FontWeight="Bold" Click="DismissButton_Click" />
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollViewer Name="Scroller" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <TextBox Name="ContentBox" IsReadOnly="True" AcceptsReturn="True"
                     BorderThickness="0" FontFamily="Cascadia Mono,Consolas,Menlo,monospace"
                     TextWrapping="NoWrap" Padding="8" />
        </ScrollViewer>
    </DockPanel>
</Window>
