		<!-- Status Bar -->
		<Grid Name="StatusBar" Grid.Column="0" Grid.Row="5" Grid.ColumnSpan="3"
		      Background="{DynamicResource StatusBarBackgroundBrush}">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="*"/>
			</Grid.ColumnDefinitions>
			<TextBlock Name="LeftStatusText" Grid.Column="0"
			           Foreground="{DynamicResource StatusBarTextBrush}" FontSize="11" FontWeight="Bold"
			           VerticalAlignment="Center" Margin="8,0,0,0"
			           Text="Left: 0 items"/>
			<TextBlock Name="RightStatusText" Grid.Column="1"
			           Foreground="{DynamicResource StatusBarTextBrush}" FontSize="11" FontWeight="Bold"
			           VerticalAlignment="Center" Margin="8,0,0,0"
			           Text="Right: 0 items"/>
		</Grid>
	</Grid>
